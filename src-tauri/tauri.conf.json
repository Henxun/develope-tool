{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevToolkit",
  "version": "0.1.0",
  "identifier": "com.example.devtoolkit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "DevToolkit",
        "width": 1320,
        "height": 860,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
